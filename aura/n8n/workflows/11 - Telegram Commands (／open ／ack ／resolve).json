      "name": "HTTP Open Alerts",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const parsed = $('Parse Command').first().json ?? {};\nconst data = $input.first().json ?? {};\n\nconst failed =\n  !!data.error ||\n  data?.ok === false ||\n  (typeof data.statusCode === 'number' && data.statusCode >= 400);\n\nif (failed) {\n  return [{\n    json: {\n      chatId: parsed.chatId,\n      message: 'Backend unreachable'\n    }\n  }];\n}\n\nlet alerts = [];\nif (Array.isArray(data.alerts)) {\n  alerts = data.alerts;\n} else if (Array.isArray(data.data?.alerts)) {\n  alerts = data.data.alerts;\n} else if (Array.isArray(data.data)) {\n  alerts = data.data;\n}\n\nif (alerts.length === 0) {\n  return [{\n    json: {\n      chatId: parsed.chatId,\n      message: '✅ No open alerts.'\n    }\n  }];\n}\n\nconst lines = alerts.slice(0, 10).map((a) => {\n  const id = a.alertId ?? a._id ?? 'N/A';\n  const patient = a.patientId ?? 'N/A';\n  const reason = Array.isArray(a.reason) ? a.reason.join(', ') : (a.reason ?? 'N/A');\n  return `- ${id} p=${patient} r=${String(reason).slice(0, 50)}`;\n});\n\nconst message = [`🚨 Open Alerts (${alerts.length})`, lines.join('\\n')].join('\\n');\nreturn [{ json: { chatId: parsed.chatId, message } }];"
      },
