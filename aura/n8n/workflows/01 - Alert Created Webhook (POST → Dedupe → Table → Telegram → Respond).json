    {
      "parameters": {
        "jsCode": "return [{ json: { notificationStatus: 'skipped' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        888,
        352
      ],
      "id": "458f4e8f-3fac-4fcb-8f6d-53db95accf3e",
      "name": "Mark Telegram Skipped"
    },
    {
      "parameters": {
        "jsCode": "const webhook = $('Webhook').first().json.body ?? {};\nconst status = $input.first().json ?? {};\nconst targetChat = ($env.TELEGRAM_CLINICIAN_CHAT_ID ?? '').toString().trim();\n\nconst payload = {\n  alertId: webhook.alertId ?? '',\n  channel: 'telegram',\n  status: status.notificationStatus ?? 'skipped',\n  timestamp: webhook.timestamp ?? new Date().toISOString(),\n  ...(targetChat ? { target: `telegram:${targetChat}` } : {}),\n  ...(status.providerMessageId ? { providerMessageId: status.providerMessageId } : {}),\n  ...(status.notificationError ? { error: status.notificationError } : {}),\n  meta: { workflow: '01' }\n};\n\nreturn [{ json: payload }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
