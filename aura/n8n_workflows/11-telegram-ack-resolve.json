    {
      "parameters": {
        "jsCode": "const parsed = $('Parse Command').first().json ?? {};\nconst result = $input.first().json ?? {};\n\nlet message = '';\nif (!parsed.alertId) {\n  message = 'Usage: /resolve <alertId>';\n} else {\n  const failed = !!result.error || result.ok === false || (typeof result.statusCode === 'number' && result.statusCode >= 400);\n  if (failed) {\n    const detail = result.error ?? result.message ?? 'backend unreachable';\n    message = `⚠️ Resolve failed: ${detail}`;\n  } else {\n    const status = result.alert?.status ?? result.status ?? '';\n    message = status === 'resolved' ? `✅ Resolved ${parsed.alertId}` : `⚠️ Resolve failed for ${parsed.alertId}`;\n  }\n}\n\nreturn [{ json: { chatId: parsed.chatId, message } }];"
      },
