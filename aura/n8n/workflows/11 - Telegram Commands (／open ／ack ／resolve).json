    {
      "parameters": {
        "jsCode": "const parsed = $('Parse Command').first().json ?? {};\nconst result = $input.first().json ?? {};\n\nlet message = '';\nif (!parsed.alertId) {\n  message = 'Usage: /ack <alertId>';\n} else if (!!result.error || (typeof result.statusCode === 'number' && result.statusCode >= 400)) {\n  message = 'Backend unreachable';\n} else if (result.ok === true && (result.alert?.status === 'acknowledged' || result.status === 'acknowledged')) {\n  message = `✅ Acknowledged: ${parsed.alertId}`;\n} else {\n  const err = result.error ?? result.message ?? 'Request failed';\n  message = `⚠️ Ack failed: ${parsed.alertId} (${err})`;\n}\n\nreturn [{ json: { chatId: parsed.chatId, message } }];"
      },
