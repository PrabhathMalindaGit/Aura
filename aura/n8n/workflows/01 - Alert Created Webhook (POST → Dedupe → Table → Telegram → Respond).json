    {
      "parameters": {
        "jsCode": "const webhook = $('Webhook').first().json.body ?? {};\nconst inserted = $('Insert row').first().json ?? {};\n\nreturn [{\n  json: {\n    ok: true,\n    saved: true,\n    duplicate: false,\n    rowId: inserted.id ?? inserted._id ?? inserted.rowId ?? null,\n    alertId: webhook.alertId ?? null,\n    patientId: webhook.patientId ?? null\n  }\n}];"
