      "id": "0959f198-2a34-46df-baad-d339d612eb88",
      "name": "Respond to Webhook"
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first().json ?? {};\nconst nested = result.result && typeof result.result === 'object' ? result.result : result;\nconst messageIdRaw = nested?.message_id ?? nested?.messageId ?? nested?.providerMessageId;\nconst providerMessageId = messageIdRaw !== undefined && messageIdRaw !== null ? String(messageIdRaw) : undefined;\n\nlet notificationError;\nif (typeof result.error === 'string') {\n  notificationError = result.error;\n} else if (result.error && typeof result.error === 'object') {\n  const errorObject = result.error;\n  if (typeof errorObject.message === 'string') {\n    notificationError = errorObject.message;\n  } else {\n    notificationError = JSON.stringify(errorObject).slice(0, 300);\n  }\n}\n\nlet webhook = {};\ntry {\n  webhook = $('Webhook').first().json.body ?? {};\n} catch {\n  webhook = {};\n}\n\nconst alertId = typeof webhook.alertId === 'string' ? webhook.alertId : '';\nconst timestamp =\n  typeof webhook.timestamp === 'string' ? webhook.timestamp : new Date().toISOString();\nconst notificationStatus = notificationError ? 'failed' : 'sent';\n\nreturn [{\n  json: {\n    alertId,\n    timestamp,\n    notificationStatus,\n    ...(providerMessageId ? { providerMessageId } : {}),\n    ...(notificationError ? { notificationError } : {})\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
