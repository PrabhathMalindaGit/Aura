      "name": "Mark Telegram Result"
    },
    {
      "parameters": {
        "jsCode": "let webhook = {};\ntry {\n  webhook = $('Webhook').first().json.body ?? {};\n} catch {\n  webhook = {};\n}\n\nreturn [{\n  json: {\n    alertId: typeof webhook.alertId === 'string' ? webhook.alertId : '',\n    timestamp:\n      typeof webhook.timestamp === 'string' ? webhook.timestamp : new Date().toISOString(),\n    notificationStatus: 'skipped'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        888,
        352
      ],
      "id": "458f4e8f-3fac-4fcb-8f6d-53db95accf3e",
      "name": "Mark Telegram Skipped"
    },
    {
      "parameters": {
        "jsCode": "const status = $input.first().json ?? {};\n\nlet webhook = {};\ntry {\n  webhook = $('Webhook').first().json.body ?? {};\n} catch {\n  webhook = {};\n}\n\nconst alertId =\n  typeof status.alertId === 'string' && status.alertId\n    ? status.alertId\n    : typeof webhook.alertId === 'string'\n      ? webhook.alertId\n      : '';\n\nconst timestamp =\n  typeof status.timestamp === 'string' && status.timestamp\n    ? status.timestamp\n    : typeof webhook.timestamp === 'string'\n      ? webhook.timestamp\n      : new Date().toISOString();\n\nconst rawStatus =\n  typeof status.notificationStatus === 'string' ? status.notificationStatus : 'attempted';\nconst allowed = ['attempted', 'sent', 'failed', 'skipped'];\nconst notificationStatus = allowed.includes(rawStatus) ? rawStatus : 'attempted';\n\nconst payload = {\n  alertId,\n  channel: 'telegram',\n  status: notificationStatus,\n  timestamp,\n  ...(status.providerMessageId ? { providerMessageId: status.providerMessageId } : {}),\n  ...(status.notificationError ? { error: status.notificationError } : {}),\n  meta: { workflow: '01' }\n};\n\nreturn [{ json: payload }];"
      },
