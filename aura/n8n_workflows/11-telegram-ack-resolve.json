      "name": "HTTP Open Alerts",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const parsed = $('Parse Command').first().json ?? {};\nconst data = $input.first().json ?? {};\n\nlet message = '';\nconst failed = !!data.error || data.ok === false || (typeof data.statusCode === 'number' && data.statusCode >= 400);\n\nif (failed) {\n  message = '⚠️ Backend unreachable.';\n} else {\n  const alerts = Array.isArray(data.alerts) ? data.alerts : [];\n  if (alerts.length === 0) {\n    message = '✅ No open alerts.';\n  } else {\n    const lines = alerts.slice(0, 10).map((a) => {\n      const id = a.alertId ?? a._id ?? 'N/A';\n      const p = a.patientId ?? 'N/A';\n      const r = a.reason ?? 'N/A';\n      return `- ${id} p=${p} r=${r}`;\n    });\n    message = `🚨 Open alerts: ${alerts.length}\\n${lines.join('\\n')}`;\n  }\n}\n\nreturn [{ json: { chatId: parsed.chatId, message } }];"
      },
      "type": "n8n-nodes-base.code",
