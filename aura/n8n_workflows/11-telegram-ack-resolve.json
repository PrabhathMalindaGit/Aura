    {
      "parameters": {
        "jsCode": "const item = $input.first().json ?? {};\nconst message = item.message ?? item.body?.message ?? item.edited_message ?? item.body?.edited_message ?? {};\nconst text = String(message.text ?? '').trim();\nconst chatId = message.chat?.id != null ? String(message.chat.id) : (item.chatId != null ? String(item.chatId) : '');\n\nconst requiredChat = ($env.TELEGRAM_CLINICIAN_CHAT_ID ?? '').toString().trim();\nconst allowed = !requiredChat || chatId === requiredChat;\n\nlet cmd = 'help';\nlet alertId = '';\n\nif (/^\\/open\\b/i.test(text)) {\n  cmd = 'open';\n} else {\n  const ackMatch = text.match(/^\\/ack\\s+([A-Za-z0-9_-]+)/i);\n  const resolveMatch = text.match(/^\\/resolve\\s+([A-Za-z0-9_-]+)/i);\n\n  if (ackMatch) {\n    cmd = 'ack';\n    alertId = ackMatch[1];\n  } else if (resolveMatch) {\n    cmd = 'resolve';\n    alertId = resolveMatch[1];\n  }\n}\n\nreturn [{\n  json: {\n    cmd,\n    alertId,\n    chatId,\n    allowed\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
