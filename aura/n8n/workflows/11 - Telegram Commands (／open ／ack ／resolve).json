    {
      "parameters": {
        "jsCode": "const item = $input.first().json ?? {};\nconst message = item.message ?? item.body?.message ?? {};\nconst rawText = String(message.text ?? '').trim();\nconst chatId = String(message.chat?.id ?? item.chatId ?? '');\n\nconst configuredChatRaw = ($env.TELEGRAM_CLINICIAN_CHAT_ID ?? '').toString().trim();\nconst isConfigured = configuredChatRaw !== '' && configuredChatRaw !== 'CHANGE_ME';\nconst configuredChatId = String(configuredChatRaw);\nconst allowed = isConfigured && chatId !== '' && chatId === configuredChatId;\n\nlet cmd = 'help';\nlet alertId = '';\n\nif (/^\\/open\\b/i.test(rawText)) {\n  cmd = 'open';\n} else if (/^\\/help\\b/i.test(rawText)) {\n  cmd = 'help';\n} else {\n  const ackMatch = rawText.match(/^\\/ack\\s+([^\\s]+)/i);\n  const resolveMatch = rawText.match(/^\\/resolve\\s+([^\\s]+)/i);\n\n  if (ackMatch) {\n    cmd = 'ack';\n    alertId = ackMatch[1];\n  } else if (resolveMatch) {\n    cmd = 'resolve';\n    alertId = resolveMatch[1];\n  }\n}\n\nreturn [{\n  json: {\n    cmd,\n    alertId,\n    chatId,\n    rawText,\n    allowed\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
