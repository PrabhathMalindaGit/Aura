# Server
PORT=3000

# Mongo
MONGO_URL=mongodb://localhost:27017/aura

# AI Service
AI_BASE_URL=http://localhost:8001

# n8n webhook (create workflow in n8n UI)
N8N_WEBHOOK_ALERT=http://localhost:5678/webhook/alert-created
N8N_RETRY_WEBHOOK_URL=
AURA_WEBHOOK_KEY=replace-with-strong-shared-secret
AURA_INTERNAL_KEY=
AURA_AI_SERVICE_KEY=replace-with-strong-ai-service-secret
JWT_SECRET=replace-with-strong-jwt-secret
PATIENT_JWT_SECRET=replace-with-strong-patient-jwt-secret
PATIENT_TOKEN_TTL=30d
CAREGIVER_JWT_SECRET=replace-with-strong-caregiver-jwt-secret
CAREGIVER_TOKEN_TTL=7d
DEMO_PATIENT_LOGIN=false
ALLOW_UNAUTH_CLINICIAN_BODY_IDS=false

# Browser origins allowed to call the server in non-local environments.
# Leave blank only for local development and automated tests.
CORS_ALLOWED_ORIGINS=https://dashboard.example.com,https://staging-dashboard.example.com

# Safety Router thresholds (mirrors AI service defaults)
PAIN_HIGH_THRESHOLD=7

# Local demo file uploads
UPLOADS_DIR=./uploads
SYMPTOM_PHOTOS_DIR=./uploads/symptoms
MAX_PHOTO_MB=5
