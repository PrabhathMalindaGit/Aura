{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node scripts/expo-start.mjs",
    "start:raw": "npx expo start --clear",
    "android": "node scripts/expo-start.mjs --android",
    "ios": "node scripts/expo-start.mjs --ios",
    "web": "npm run env:web && node scripts/expo-start.mjs --web",
    "test": "vitest run",
    "web:guardrails": "node scripts/web-stability-check.mjs",
    "a11y:smoke": "node scripts/a11y-smoke-check.mjs",
    "qa:web": "npx tsc -p tsconfig.json --noEmit && npm run web:guardrails && npm run a11y:smoke",
    "qa:web:boot": "npm run web",
    "env:web": "cp .env.web .env && rm -f .env.local && echo 'Using WEB env (.env -> localhost)'",
    "env:device": "cp .env.device .env.local && echo 'Using DEVICE env (.env.local <- .env.device)'",
    "dev:web": "npm run env:web && npm run qa:web:boot",
    "dev:device": "npm run env:device && npx expo start --tunnel --clear --port 8082",
    "dev:device:lan": "npm run env:device && AURA_DEV_PORT=8082 node scripts/expo-start.mjs --lan --clear"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-segmented-control/segmented-control": "2.5.7",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react-test-renderer": "^19.1.0",
    "@types/react": "~19.1.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "private": true
}
