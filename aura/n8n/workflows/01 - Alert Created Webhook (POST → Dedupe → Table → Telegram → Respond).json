      "parameters": {
        "jsCode": "const chatId = ($env.TELEGRAM_CLINICIAN_CHAT_ID ?? '').toString().trim();\nconst telegramEnabled = !!chatId && chatId !== 'CHANGE_ME';\n\nreturn [{\n  json: {\n    ...$json,\n    telegramEnabled\n  }\n}];"
