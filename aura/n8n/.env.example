# This is a reference template for n8n-related values.
# Docker Compose reads the project root `.env`, not this file, unless Compose is
# changed to use `env_file`.

# Target Telegram chat/group id for clinician alerts
TELEGRAM_CLINICIAN_CHAT_ID=CHANGE_ME

# Optional target Telegram chat/group id for dev error monitoring
TELEGRAM_DEV_CHAT_ID=CHANGE_ME

# n8n -> backend base URL (Docker on macOS)
AURA_API_BASE=http://host.docker.internal:3000

# n8n -> backend callback/internal route key
AURA_WEBHOOK_KEY=

# Backend -> n8n alert-created webhook ingress key
AURA_N8N_WEBHOOK_KEY=

# External/manual caller -> n8n List Alerts Proxy key
AURA_N8N_API_KEY=

# Store the Telegram bot token in n8n Credentials UI or local secret storage.
# Do not commit real bot tokens or real chat IDs.
