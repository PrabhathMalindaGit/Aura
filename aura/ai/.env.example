# Aura AI Service (Safety Router)
HOST=127.0.0.1
PORT=8001

# Risk rule thresholds
PAIN_HIGH_THRESHOLD=7

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Shared secret required on non-health routes.
AURA_AI_SERVICE_KEY=replace-with-strong-ai-service-secret

# Optional static rehabilitation knowledge PGVector retrieval.
# Defaults are fallback-safe and do not require Docker/Postgres.
RAG_PGVECTOR_ENABLED=false
RAG_PGVECTOR_DATABASE_URL=postgresql://aura:aura@localhost:5432/aura_vectors
RAG_PGVECTOR_FALLBACK_ENABLED=true
RAG_PGVECTOR_TOP_K=2
RAG_PGVECTOR_DIMENSIONS=384
